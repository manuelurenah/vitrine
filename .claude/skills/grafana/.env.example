# grafana skill config. Copy to `.env` IN THIS DIRECTORY and fill in:
#   cp .claude/skills/grafana/.env.example .claude/skills/grafana/.env
#
# The skill reads this dir's `.env` first, then falls back to the project-root
# `.env`; real shell env vars always win. A `.env` here is gitignored. With no
# config at all, the defaults below target the local `pnpm dev:up` stack.

# Base URL of the Grafana instance.
GRAFANA_URL=http://localhost:3001

# Preferred auth: a Grafana service-account token (Bearer).
# Admin role is required to create datasources. Create one in Grafana under
# Administration -> Service accounts -> Add service account -> Add token.
# GRAFANA_TOKEN=

# Basic-auth fallback (the local otel-lgtm default is admin/admin).
# Ignored when GRAFANA_TOKEN is set.
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin
