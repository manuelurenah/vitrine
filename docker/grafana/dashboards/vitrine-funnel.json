  "panels": [
    {
      "id": 1,
      "type": "bargauge",
      "title": "Funnel â€” event counts (range)",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 0 },
      "options": { "orientation": "horizontal", "displayMode": "gradient", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "refId": "A", "datasource": { "type": "loki", "uid": "loki" }, "expr": "sum by (event_name) (count_over_time({service_name=\"unknown_service\"} | logfmt | kind=`event` [$__range]))", "queryType": "instant", "legendFormat": "{{event_name}}" }
      ]
    },
