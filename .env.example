# --- Civitai OAuth App ----------------------------------------------------
# Create at https://civitai.com/user/account → OAuth Apps.
#   Client type:  Confidential (server-side app) — this starter holds the secret.
#   Grants:       authorization_code, refresh_token
#   Redirect URI: ${NEXT_PUBLIC_APP_URL}/api/auth/callback/civitai
#
# Scopes the OAuth App must grant (must match REQUESTED_SCOPES in src/lib/scopes.ts):
#   UserRead         — read profile + Buzz balance
#   BuzzRead         — show balance and cost preview
#   AIServicesRead   — read generation history
#   AIServicesWrite  — submit a generation (implicitly debits the user's Buzz)
#
# To add more scopes after the fact: extend REQUESTED_SCOPES in src/lib/scopes.ts
# (see `/add-oauth-scope` slash command) AND grant them on the OAuth App page.
# Existing sessions need to log out + back in to re-consent.
CIVITAI_CLIENT_ID=
CIVITAI_CLIENT_SECRET=

# Long, random string used to seal session cookies (AES-256-GCM via @civitai/app-sdk).
# Generate one with: `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`
SESSION_SECRET=

# Public base URL of this app. The callback path is appended to this to form the redirect URI.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Civitai base URL. Override to a dev server (e.g. http://localhost:3000) when developing
# against a local civitai/civitai checkout. Leave default in production.
NEXT_PUBLIC_CIVITAI_BASE_URL=https://civitai.com

# Uncomment if your Civitai dev host uses a self-signed cert. Disables Node TLS
# verification for the whole process — dev only, never in production.
# NODE_TLS_REJECT_UNAUTHORIZED=0

# --- Vitrine local infra (matches docker-compose.yml) ---------------------
# Same var names in prod, just swap endpoints (Vercel Postgres / R2 / Upstash).
# Boot with `pnpm dev:up`. See docs/project-overview.md for the full plan.
DATABASE_URL=postgres://app:app@localhost:5432/vitrine

S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET_UPLOADS=uploads
S3_BUCKET_ASSETS=assets
S3_PUBLIC_URL=http://localhost:9000

# --- OpenRouter (campaign ad copy generation) -----------------------------
# Used by src/lib/adCopy.ts to generate per-tile headline/subhead/CTA that
# get baked into campaign creatives. Optional: when OPENROUTER_API_KEY is
# unset, cook routes fall back to a deterministic template derived from the
# brief (no LLM call). Grab a free key at https://openrouter.ai/keys.
# OPENROUTER_API_KEY=
# Primary model for ad-copy drafting. Used as the first entry in the
# fallback chain when OPENROUTER_MODELS is unset. The default chain is
# all paid (no shared free-tier quotas → no 429 churn) and costs roughly
# $0.0002 per brief draft.
# OPENROUTER_MODEL=google/gemini-2.5-flash-lite
#
# Explicit comma-separated fallback chain. Each model is tried in order
# until one returns a usable response.
# Defaults to: google/gemini-2.5-flash-lite, openai/gpt-4.1-nano
# OPENROUTER_MODELS=google/gemini-2.5-flash-lite,openai/gpt-4.1-nano
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- e2e (playwright) -----------------------------------------------------
# Optional. Set these for `pnpm test:e2e`. The test runner boots a second
# `next dev` on TEST_PORT against this DB, with MSW intercepting Civitai +
# orchestrator HTTP calls.
TEST_DATABASE_URL=postgres://app:app@localhost:5432/vitrine_test
# Setting MOCK_CIVITAI=1 in this app process enables MSW (handled by
# instrumentation.ts). Playwright's webServer block already sets it for the
# test server — leave unset for `pnpm dev`.
# MOCK_CIVITAI=1
# By default `pnpm test:e2e` runs FULLY OFFLINE — no Civitai dev server, no
# real account, parallel workers, each with its own synthetic test user. The
# 00-auth-flow spec (real OAuth round-trip) is skipped. To run it, start your
# local Civitai dev server and set both:
# E2E_REAL_OAUTH=1
# TEST_USER_ID=1

# --- prompt-lab (dev image-prompt iteration CLI) --------------------------
# Script-only (NOT read by the app / src/lib/env.ts). Paste the sealed
# civ_session cookie from a real `pnpm dev` login (devtools → Application →
# Cookies → civ_session). The CLI unseals it with SESSION_SECRET and
# self-refreshes via the OAuth refresh token. Re-paste ~monthly.
# PROMPT_LAB_SESSION=
# Raw access-token fallback — used as-is, no refresh (quick probes only).
# PROMPT_LAB_ACCESS_TOKEN=
