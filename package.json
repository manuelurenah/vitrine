{
  "name": "vitrine",
  "version": "0.1.0",
  "private": true,
  "description": "Vitrine — Civitai OAuth + Buzz-powered campaign + photoshoot generator.",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "civitai",
    "oauth",
    "pkce",
    "starter",
    "template",
    "nextjs",
    "next",
    "app-router",
    "ai",
    "generation"
  ],
  "homepage": "https://github.com/civitai/civitai-app-starters/tree/main/starters/next-app#readme",
  "bugs": "https://github.com/civitai/civitai-app-starters/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/civitai/civitai-app-starters.git",
    "directory": "starters/next-app"
  },
  "scripts": {
    "dev": "next dev -p 3333",
    "dev:up": "docker compose up -d",
    "dev:down": "docker compose down",
    "dev:reset": "docker compose down -v && docker compose up -d",
    "prompt-lab": "node --env-file=.env --import tsx scripts/prompt-lab/run.ts",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check:env": "node scripts/check-env.mjs",
    "db:generate": "node --env-file=.env ./node_modules/drizzle-kit/bin.cjs generate",
    "db:migrate": "node --env-file=.env ./node_modules/drizzle-kit/bin.cjs migrate",
    "db:push": "node --env-file=.env ./node_modules/drizzle-kit/bin.cjs push",
    "db:studio": "node --env-file=.env ./node_modules/drizzle-kit/bin.cjs studio",
    "test:db:setup": "node --env-file=.env scripts/db-test-setup.mjs",
    "test:server": "node --env-file=.env scripts/test-server.mjs",
    "test:e2e": "node --env-file=.env ./node_modules/@playwright/test/cli.js test",
    "test:e2e:ui": "node --env-file=.env ./node_modules/@playwright/test/cli.js test --ui",
    "test:e2e:install": "playwright install --with-deps chromium",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1057.0",
    "@aws-sdk/s3-request-presigner": "^3.1057.0",
    "@civitai/app-sdk": "^0.6.0",
    "@t3-oss/env-nextjs": "^0.13.0",
    "drizzle-orm": "^0.45.2",
    "jszip": "^3.10.1",
    "lucide-react": "^1.17.0",
    "motion": "^12.40.0",
    "next": "^16.2.6",
    "openai": "^6.41.0",
    "pg": "^8.21.0",
    "react": "^19.0.0",
    "react-colorful": "^5.7.0",
    "react-dom": "^19.0.0",
    "sharp": "^0.35.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@playwright/test": "^1.57.0",
    "@types/node": "^25.9.1",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.0",
    "eslint-config-next": "^16.2.6",
    "msw": "^2.14.6",
    "postcss": "^8.4.49",
    "server-only": "^0.0.1",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.22.4",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
